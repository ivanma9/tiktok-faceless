[Unit]
Description=TikTok Faceless Autonomous Creator Pipeline
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/tiktok-faceless
ExecStart=/usr/local/bin/uv run python main.py
Restart=always
RestartSec=5
EnvironmentFile=/etc/tiktok-faceless/env

# Logging to systemd journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tiktok-faceless

[Install]
WantedBy=multi-user.target
